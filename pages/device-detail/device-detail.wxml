<view class="container">
  <view class="map-section">
    <map
      id="deviceMap"
      class="device-map"
      latitude="{{device.latitude || 39.9042}}"
      longitude="{{device.longitude || 116.4074}}"
      scale="15"
      markers="{{markers}}"
      show-location
    ></map>
    <view class="map-overlay">
      <view class="overlay-left">
        <view class="device-name-row">
          <text class="device-name-text">{{device.name}}</text>
          <view class="alarm-badge {{device.status}}">
            <text wx:if="{{device.status === 'alarm'}}">报警中</text>
            <text wx:elif="{{device.status === 'normal'}}">正常</text>
            <text wx:else>离线</text>
          </view>
        </view>
        <view class="address-row">
          <text class="address-icon">📍</text>
          <text class="address-text">{{device.address || '请设置安装位置'}}</text>
        </view>
      </view>
      <view class="overlay-right">
        <view class="quick-action nav-action" bindtap="startNavigation">
          <image class="action-img" src="/images/导航.png" mode="aspectFit" />
          <text class="action-label">导航</text>
        </view>
        <view class="quick-action audio-action" bindtap="goAudioPage">
          <image class="action-img" src="/images/录音开启.png" mode="aspectFit" />
          <text class="action-label">录音</text>
        </view>
        <view class="quick-action setting-action" bindtap="goSetting">
          <image class="action-img" src="/images/设置.png" mode="aspectFit" />
          <text class="action-label">设置</text>
        </view>
      </view>
    </view>
  </view>

  <white-card title="紧急联系人" customClass="contact-card" showRightContent="true">
    <view slot="rightContent">
      <text class="add-btn" bindtap="showAddContact">＋</text>
    </view>

    <block wx:for="{{device.contacts}}" wx:key="id">
      <view class="contact-item-wrap {{swipeId === item.id && swipeOffset < 0 ? 'swiped' : ''}}">
        <view 
          class="contact-item" 
          bindtouchstart="touchStart" 
          bindtouchmove="touchMove" 
          bindtouchend="touchEnd" 
          data-id="{{item.id}}"
          style="transform: translateX({{swipeId === item.id ? swipeOffset : 0}}px)"
        >
          <view class="contact-info">
            <view class="contact-name">{{item.name}}</view>
            <view class="contact-phone">{{item.phone}}</view>
          </view>
        </view>
        <view class="delete-btn" data-id="{{item.id}}" bindtap="deleteContact">删除</view>
      </view>
    </block>

    <view wx:if="{{device.contacts.length === 0}}" class="empty-state">
      <text class="empty-icon">📵</text>
      <text class="empty-text">暂无紧急联系人</text>
      <text class="empty-hint">点击右上角「＋」添加联系人</text>
    </view>
  </white-card>

  <view class="unbind-section">
    <view class="unbind-btn" bindtap="confirmUnbind">解除绑定</view>
  </view>
</view>

<!-- 修改设备名称弹窗：变量名匹配 -->
<view class="modal-mask" wx:if="{{showEditNameModal}}" bindtap="closeEditNameModal"></view>
<view class="modal-container" wx:if="{{showEditNameModal}}">
  <view class="modal-title">修改设备名称</view>
  <view class="modal-form">
    <input 
      class="modal-input" 
      type="text" 
      placeholder="请输入设备名称" 
      bindinput="onNameInput"
      value="{{tempName}}"
      maxlength="20"
    />
  </view>
  <view class="modal-btn-group">
    <custom-button text="取消" type="normal" bind:click="closeEditNameModal" customClass="modal-btn-half"></custom-button>
    <custom-button text="保存" type="orange" bind:click="saveName" customClass="modal-btn-half"></custom-button>
  </view>
</view>

<view class="modal-mask" wx:if="{{showAddContactModal}}" bindtap="closeAddContactModal"></view>
<view class="modal-container" wx:if="{{showAddContactModal}}">
  <view class="modal-title">添加紧急联系人</view>
  <view class="modal-form">
    <view class="form-item">
      <label class="form-label">姓名</label>
      <input 
        class="form-input" 
        type="text" 
        placeholder="请输入联系人姓名" 
        bindinput="onContactNameInput"
        value="{{tempContactName}}"
        maxlength="20"
      />
    </view>
    <view class="form-item">
      <label class="form-label">手机号</label>
      <input 
        class="form-input" 
        type="number" 
        placeholder="请输入11位手机号" 
        bindinput="onContactPhoneInput"
        value="{{tempContactPhone}}"
        maxlength="11"
      />
    </view>
  </view>
  <view class="modal-btn-group">
    <custom-button 
      text="取消" 
      type="normal" 
      bind:click="closeAddContactModal"
      class="modal-btn-half"
    ></custom-button>
    <custom-button 
      text="确认添加" 
      type="orange" 
      bind:click="saveContact"
      class="modal-btn-half"
    ></custom-button>
  </view>
</view>
<view class="container">
  <view class="head-card">
    <view class="head-left">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/avatar.png'}}" mode="aspectFill" />
    </view>
    <view class="head-center">
      <view class="username">
        {{ isLogin ? userInfo.nickName || userInfo.userName || '用户' : '未登录用户' }}
      </view>
      <view class="sub-text">
        {{ isLogin ? (userInfo.phone ? userInfo.phone : '已绑定报警服务') : '登录后可接收报警信息' }}
      </view>
    </view>
    <view class="head-right">
      <button
        wx:if="{{!isLogin}}"
        class="login-btn"
        bindtap="goLogin"
      >
        登录
      </button>
      <view wx:else class="login-tag">已登录</view>
    </view>
  </view>

  <white-card title="我的设备" customClass="device-card" showRightContent="true">
    <view slot="rightContent" class="add-btn-wrapper">
      <text class="add-btn" bindtap="goBindDevice">＋</text>
    </view>

    <block wx:for="{{devices}}" wx:key="id">
      <view class="device-item" bindtap="goDeviceDetail" data-id="{{item.id}}">
        <view class="device-info">
          <view class="device-name">{{item.name}}</view>
        </view>
        <view class="device-status-group">
          <view class="device-status {{item.status}}">{{item.statusText}}</view>
          <view class="device-arrow">›</view>
        </view>
      </view>
    </block>

    <view wx:if="{{devices.length === 0}}" class="empty-state">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂未绑定设备</text>
      <text class="empty-hint">点击右上角「＋」添加设备</text>
    </view>
  </white-card>
</view>

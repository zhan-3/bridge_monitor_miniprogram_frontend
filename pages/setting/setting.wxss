/* 全局样式重置 - 统一橙色主题 */
page {
  background-color: #f5f7fa;
  font-size: 28rpx;
  color: #333;
}
.setting-container {
  width: 100%;
  height: 100vh;
  box-sizing: border-box;
}

/* 滚动主内容 */
.setting-scroll {
  height: 100vh; 
  padding: 30rpx;
  box-sizing: border-box;
}

/* 卡片样式适配 - 统一项目风格 */
.setting-module-card {
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
/* 覆盖white-card组件的标题样式，统一橙色 */
.setting-module-card .header-title {
  color: #FF7A00 !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
}
/* 卡片底部说明文字样式 */
.setting-module-card .footer-text {
  font-size: 24rpx !important;
  color: #999 !important;
  margin-top: 10rpx !important;
}

/* 设置项通用样式 - 保留原有逻辑 */
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.setting-item:last-child {
  border-bottom: none;
}
.item-label {
  font-size: 28rpx;
}
.item-switch {
  transform: scale(0.8);
}
.item-picker {
  color: #666;
  font-size: 26rpx;
  padding-right: 20rpx;
  background: url("data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTIiIGhlaWdodD0iNiIgdmlld0JveD0iMCAwIDEyIDYiIGZpbGw9Im5vbmUiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PHBhdGggZD0iTTEwIDBIMnYxLjVMNiA1bDQtMy41VjBIMTB6IiBmaWxsPSJ3aGl0ZSIvPgo8L3N2Zz4=") no-repeat right center;
  background-size: 12rpx 6rpx;
}

/* 保存按钮容器 */
.save-btn-container {
  padding: 20rpx 0;
}
/* 保存按钮样式 - 统一橙色主题 */
.save-btn {
  width: 100% !important;
  height: 90rpx !important;
  line-height: 90rpx !important;
  border-radius: 15rpx !important;
  font-size: 32rpx !important;
  font-weight: 500 !important;
  --orange-primary: #FF7A00;
  --orange-dark: #E86A00;
}

/* 设备位置设置卡片 */
.location-card {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
}

.location-map {
  height: 180px;
  background: #f5f5f5;
}

.preview-map {
  width: 100%;
  height: 100%;
}

.map-placeholder {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}

.location-info {
  padding: 16px;
  border-bottom: 1px solid #f0f0f0;
}

.location-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
}

.location-address {
  display: flex;
  align-items: flex-start;
  gap: 6px;
}

.address-icon {
  font-size: 24rpx;
  flex-shrink: 0;
  margin-top: 2px;
}

.address-text {
  font-size: 26rpx;
  color: #666;
  flex: 1;
  word-break: break-all;
}

.location-actions {
  padding: 12px 16px;
}

.location-btn {
  width: 100%;
  height: 80rpx;
  background: var(--orange-primary);
  color: #fff;
  border: none;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.location-btn .btn-icon {
  margin-right: 8px;
  font-size: 32rpx;
}

.location-btn::after {
  border: none;
}

/* 设备信息网格 */
.device-info-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 10rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.name-item {
  cursor: pointer;
}

.info-value-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.edit-icon {
  font-size: 24rpx;
  color: #FF7A00;
}

.info-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  text-align: center;
  word-break: break-all;
}

.sn-value {
  font-size: 22rpx;
  color: #666;
}

.status-badge {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.status-badge.normal {
  background: #e6f7e6;
  color: #52c41a;
}

.status-badge.alarm {
  background: #fff1e6;
  color: #FF7A00;
}

.status-badge.offline {
  background: #f5f5f5;
  color: #999;
}

/* 编辑弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.modal-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  z-index: 1001;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 40rpx;
  color: #333;
}

.modal-form {
  margin-bottom: 40rpx;
}

.modal-input {
  width: 100%;
  height: 90rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-btn-group {
  display: flex;
  gap: 20rpx;
}

.modal-btn-half {
  flex: 1;
}
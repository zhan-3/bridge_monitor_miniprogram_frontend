.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FF7A00 0%, #FF9933 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 30px 40px;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50px;
}

.logo-icon {
  font-size: 64px;
  margin-bottom: 16px;
}

.title {
  font-size: 22px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8px;
}

.subtitle {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.8);
}

.login-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 50px;
  width: 100%;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-num {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 6px;
}

.step-item.active .step-num {
  background: #fff;
  color: var(--orange-primary);
}

.step-text {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.7);
}

.step-item.active .step-text {
  color: #fff;
  font-weight: 500;
}

.step-line {
  width: 40px;
  height: 2px;
  background: rgba(255, 255, 255, 0.3);
  margin: 0 8px;
  margin-bottom: 20px;
}

.step-line.active {
  background: #fff;
}

.login-content {
  width: 100%;
  margin-bottom: 30px;
}

.login-btn {
  width: 100%;
  height: 50px;
  background: #fff;
  border-radius: 25px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
}

.login-btn.primary {
  background: #fff;
}

.login-btn .btn-icon {
  font-size: 20px;
  margin-right: 8px;
}

.login-btn .btn-text {
  font-size: 16px;
  color: #333;
  font-weight: 500;
}

.step-hint {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
}

/* 手机号弹窗 */
.phone-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.phone-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 300px;
  background: #fff;
  border-radius: 12px;
  padding: 24px;
  z-index: 101;
}

.modal-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 8px;
}

.modal-desc {
  font-size: 13px;
  color: #999;
  text-align: center;
  margin-bottom: 20px;
}

.modal-input {
  width: 100%;
  height: 44px;
  border: 1px solid #ddd;
  border-radius: 8px;
  padding: 0 12px;
  font-size: 15px;
  margin-bottom: 12px;
  box-sizing: border-box;
}

.modal-btns {
  display: flex;
  margin-top: 20px;
}

.modal-btn {
  flex: 1;
  height: 40px;
  border-radius: 20px;
  font-size: 15px;
  border: none;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
  margin-right: 10px;
}

.modal-btn.confirm {
  background: #FF7A00;
  color: #fff;
  margin-left: 10px;
}

.modal-input.input-error {
  border-color: #ff4d4f;
}

.input-error-tip {
  font-size: 12px;
  color: #ff4d4f;
  margin-top: -8px;
  margin-bottom: 4px;
  display: block;
}

.modal-btn.btn-disabled {
  background: #ccc;
  color: #fff;
}

<view class="login-page">
  <view class="login-header">
    <view class="logo-icon">🔔</view>
    <text class="title">紧急报警系统</text>
    <text class="subtitle">登录后可接收报警信息</text>
  </view>

  <view class="login-steps">
    <view class="step-item {{step >= 1 ? 'active' : ''}}">
      <view class="step-num">1</view>
      <text class="step-text">微信登录</text>
    </view>
    <view class="step-line {{step >= 2 ? 'active' : ''}}"></view>
    <view class="step-item {{step >= 2 ? 'active' : ''}}">
      <view class="step-num">2</view>
      <text class="step-text">授权信息</text>
    </view>
    <view class="step-line {{step >= 3 ? 'active' : ''}}"></view>
    <view class="step-item {{step >= 3 ? 'active' : ''}}">
      <view class="step-num">3</view>
      <text class="step-text">验证手机</text>
    </view>
  </view>

  <view class="login-content">
    <block wx:if="{{step === 1}}">
      <button class="login-btn" bindtap="doBaseLogin">
        <text class="btn-icon">微</text>
        <text class="btn-text">微信登录</text>
      </button>
    </block>

    <block wx:elif="{{step === 2}}">
      <button class="login-btn" bindtap="getUserInfo">
        <text class="btn-icon">👤</text>
        <text class="btn-text">授权头像昵称</text>
      </button>
    </block>

    <block wx:elif="{{step === 3}}">
      <button 
        class="login-btn primary" 
        open-type="getPhoneNumber" 
        bindgetphonenumber="onGetPhoneNumber"
      >
        <text class="btn-icon">📱</text>
        <text class="btn-text">授权手机号</text>
      </button>
    </block>
  </view>

  <view class="step-hint">
    <text wx:if="{{step === 1}}">点击上方按钮进行微信登录</text>
    <text wx:elif="{{step === 2}}">授权后可完善您的个人资料</text>
    <text wx:elif="{{step === 3}}">授权手机号用于接收报警通知</text>
  </view>
</view>
